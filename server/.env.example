# ─────────────────────────────────────────────
# swissgarden Perfumes — Server Environment Example
# ─────────────────────────────────────────────

NODE_ENV=development  # Use 'development' for testing, 'production' for deployment

# ── MongoDB ──────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/swissgarden-perfumes

# ── JWT ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ── Razorpay ─────────────────────────────────
# Get these from: https://dashboard.razorpay.com/app/keys
# Test keys for development, Live keys for production
RAZORPAY_KEY_ID=rzp_test_your_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_test_secret
# Get webhook secret from: Razorpay Dashboard → Webhooks → your webhook → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Email (Nodemailer) ───────────────────────
# The domain's mail is hosted on GoDaddy Workspace Email (verify with the MX
# records: smtp.secureserver.net / mailstore1.secureserver.net, SPF includes
# secureserver.net). secure/TLS is auto-detected from SMTP_PORT
# (465 = implicit TLS, 587 = STARTTLS) — see server/utils/sendEmail.js.
# FROM_EMAIL must match SMTP_EMAIL to satisfy SPF/DKIM alignment.
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_EMAIL=support@yourdomain.com
SMTP_PASSWORD=your_mailbox_password_here
FROM_NAME=SwissGarden Perfumes
FROM_EMAIL=support@yourdomain.com
# Recipient for store alerts (contact form, RTO, new returns); falls back to SMTP_EMAIL
ADMIN_EMAIL=support@yourdomain.com
# IMAP (imap.secureserver.net, port 993 SSL) is not consumed by the app —
# only outbound SMTP sending is implemented.

# ── Client URL ───────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Port ─────────────────────────────────────
PORT=5000

# ── OpenRouter (AI Chatbot) ──────────────────
# Get key from: https://openrouter.ai/keys
# IMPORTANT: Rotate this key after first deployment — never commit the real key
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-chat-v3-0324:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free
# Set to false to exclude shipping address/phone from LLM context
CHAT_INCLUDE_PII=true
